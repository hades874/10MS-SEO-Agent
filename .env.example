# --- Database (Neon Postgres via Vercel Marketplace) ---
# Get this from Vercel > Storage > your Neon DB > .env.local, or `vercel env pull`
DATABASE_URL="postgres://user:pass@host/db?sslmode=require"

# --- AI provider ---
# Default = Google Gemini (free tier covers BOTH chat AND embeddings).
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=""

# Optional: use OpenRouter for CHAT models instead of Gemini. Embeddings still
# require the Google key above (OpenRouter has no embeddings).
# AI_PROVIDER="openrouter"
# OPENROUTER_API_KEY=""

# Model selection (overridable). Defaults are Gemini free-tier model ids.
SEO_DRAFT_MODEL="gemini-2.5-flash"
SEO_TAG_MODEL="gemini-2.5-flash-lite"
SEO_EMBED_MODEL="gemini-embedding-001"

# Embedding vector size. gemini-embedding-001 is pinned to this via outputDimensionality.
EMBED_DIM="768"

# Brand constants used in generated schema/OG
BRAND_NAME="10 Minute School"
SITE_ORIGIN="https://10minuteschool.com"
CDN_ORIGIN="https://cdn.10minuteschool.com"

# --- SERP provider (Phase 3 rank tracking + competitor discovery) ---
# Default with no key = DuckDuckGo scraping (free, but rate-limits under load and
# isn't Google). Set ONE of these (both have FREE tiers, no paid plan) for reliable
# results — Serper returns actual Google results and is recommended:
# SERPER_API_KEY=""          # https://serper.dev (free 2,500 queries)
# BRAVE_SEARCH_API_KEY=""    # https://brave.com/search/api (free tier)

# --- AI-search visibility engines (Phase 4, optional) ---
# Gemini (Google-grounded) is wired via the Google key above. Add either of these to
# auto-activate the extra engines in the tracking panel — they speak the same
# /chat/completions protocol. Without a key the slot stays "not configured".
# OPENAI_API_KEY=""          # ChatGPT (model memory, non-grounded — weaker signal)
# OPENAI_MODEL="gpt-4o-mini"
# PERPLEXITY_API_KEY=""      # Perplexity (web-grounded — strong GEO signal)
# PERPLEXITY_MODEL="sonar"

# --- Paid keyword research (Phase 4, optional scaffold) ---
# Free default = Google Autocomplete (demand = suggestion breadth). Setting this
# switches to the DataForSEO adapter (real search volume) — adapter is scaffolded.
# DATAFORSEO_API_KEY=""

# --- Google Search Console rank (Phase 4, optional scaffold) ---
# SERP-based rank is the live default. Set these to enable the GSC adapter (exact
# impressions/clicks/CTR) once Search Console access is granted — adapter is scaffolded.
# GSC_SITE_URL="https://10minuteschool.com"
# GSC_SERVICE_ACCOUNT_JSON=""   # or:
# GSC_REFRESH_TOKEN=""

# --- Cron protection (set in production for /api/cron/recheck) ---
# CRON_SECRET=""
