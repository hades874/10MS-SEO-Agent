# --- Database (Neon Postgres via Vercel Marketplace) ---
# Get this from Vercel > Storage > your Neon DB > .env.local, or `vercel env pull`
DATABASE_URL="postgres://user:pass@host/db?sslmode=require"

# --- AI provider ---
# Default = Google Gemini (free tier covers BOTH chat AND embeddings).
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=""

# Optional: use OpenRouter for CHAT models instead of Gemini. Embeddings still
# require the Google key above (OpenRouter has no embeddings).
# AI_PROVIDER="openrouter"
# OPENROUTER_API_KEY=""

# Model selection (overridable). Defaults are Gemini free-tier model ids.
SEO_DRAFT_MODEL="gemini-2.5-flash"
SEO_TAG_MODEL="gemini-2.5-flash-lite"
SEO_EMBED_MODEL="gemini-embedding-001"

# Embedding vector size. gemini-embedding-001 is pinned to this via outputDimensionality.
EMBED_DIM="768"

# Brand constants used in generated schema/OG
BRAND_NAME="10 Minute School"
SITE_ORIGIN="https://10minuteschool.com"
CDN_ORIGIN="https://cdn.10minuteschool.com"
